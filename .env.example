# ----------------------------------------
# LLM Configuration
# ----------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ----------------------------------------
# PostgreSQL Configuration
# ----------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=appointment_db

# The API and MCP Server use this to connect to the DB container.
# Note the host is "db", which maps directly to the service name in docker-compose.yml
DATABASE_URL=YOUR_DATABASE_URL

# ----------------------------------------
# Internal Networking
# ----------------------------------------
# The FastAPI agent uses this to discover the MCP tools over SSE
MCP_SERVER_URL=http://mcp-server:8001/sse

RESEND_API_KEY=YOUR_RESEND_API_KEY

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# ----------------------------------------
# Google Calendar Integration
# ----------------------------------------
# Either set GOOGLE_SERVICE_ACCOUNT_FILE to a JSON file path mounted in container
# or provide the full JSON contents in GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_MAP_JSON=
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

# ----------------------------------------
# Doctor Notification Channel (Slack)
# ----------------------------------------
SLACK_WEBHOOK_URL=