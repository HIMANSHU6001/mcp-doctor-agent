# ----------------------------------------
# LLM Configuration
# ----------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ----------------------------------------
# PostgreSQL Configuration
# ----------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=appointment_db

# The API and MCP Server use this to connect to the DB container.
# Note the host is "db", which maps directly to the service name in docker-compose.yml
DATABASE_URL=postgresql://postgres:supersecret@db:5432/appointment_db

# ----------------------------------------
# Internal Networking
# ----------------------------------------
# The FastAPI agent uses this to discover the MCP tools over SSE
MCP_SERVER_URL=http://mcp-server:8001/sse

# Resend is used for booking emails to both patient and doctor.
# In testing mode, recipients usually need to be verified in your Resend account.
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=onboarding@resend.dev

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# ----------------------------------------
# Doctor Notification Channel (Slack)
# ----------------------------------------
SLACK_WEBHOOK_URL=